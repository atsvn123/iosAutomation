#!/bin/sh
# roothide postinst — uses jbroot command to resolve dynamic jailbreak root path

# Register app with SpringBoard
UICACHE=$(jbroot /usr/bin/uicache 2>/dev/null)
if [ -x "$UICACHE" ]; then
    "$UICACHE" -a
fi

# sudoers entry for zxtouchb
ZXTOUCHB=$(jbroot /usr/bin/zxtouchb)
SUDOERS_D=$(jbroot /etc/sudoers.d)
if [ -d "$SUDOERS_D" ]; then
    echo "mobile ALL=(root) NOPASSWD:$ZXTOUCHB" > "$SUDOERS_D/zxtouch"
    chmod 440 "$SUDOERS_D/zxtouch"
fi

# Create required app directories
mkdir -p /var/mobile/Library/ZXTouch/scripts/recording/
mkdir -p /var/mobile/Library/ZXTouch/scripts/examples/
mkdir -p /var/mobile/Library/ZXTouch/config/tweak/
mkdir -p /var/mobile/Library/ZXTouch/coreutils/ScriptRuntime/

# Copy bundled example scripts. These are maintained by the package, so refresh
# them on upgrade while leaving unrelated user scripts alone.
EXAMPLES=$(jbroot /usr/share/zxtouch/examples)
if [ -d "$EXAMPLES" ]; then
    cp -Rf "$EXAMPLES/"* /var/mobile/Library/ZXTouch/scripts/examples/ 2>/dev/null || true
fi

REGISTRY=/var/mobile/Library/ZXTouch/config/tweak/script_registry.plist
REGISTRY_SOURCE=$(jbroot /usr/share/zxtouch/script-registry.plist)
if [ -f "$REGISTRY_SOURCE" ]; then
    cp -f "$REGISTRY_SOURCE" "$REGISTRY"
fi

# Patch add_datetime.sh shebang — roothide has no fixed /var/jb path
SH=$(jbroot /bin/sh)
SCRIPT=/var/mobile/Library/ZXTouch/coreutils/ScriptRuntime/add_datetime.sh
cat > "$SCRIPT" << 'EOF'
#!/bin/sh
OUTPUT=/var/mobile/Library/ZXTouch/coreutils/ScriptRuntime/output
DATE=$(jbroot /usr/bin/date 2>/dev/null)
if [ ! -x "$DATE" ]; then DATE=/usr/bin/date; fi
if [ ! -x "$DATE" ]; then DATE=/bin/date; fi
echo "$($DATE '+%m-%d-%Y %T'): Start running script. Script path: $1" >> "$OUTPUT"
while IFS= read -r line; do
    echo "$($DATE '+%m-%d-%Y %T'): $line" >> "$OUTPUT"
done
EOF
if [ -f "$SCRIPT" ]; then
    printf '#!%s\n' "$SH" > /tmp/adt_new.sh
    tail -n +2 "$SCRIPT" >> /tmp/adt_new.sh
    mv /tmp/adt_new.sh "$SCRIPT"
    chmod +x "$SCRIPT"
fi
touch /var/mobile/Library/ZXTouch/coreutils/ScriptRuntime/output
chown -R mobile:mobile /var/mobile/Library/ZXTouch

# Fix broken python3 symlink — Procursus points it to /bin/python3 which doesn't resolve on roothide
# Also skip python3.7 which is broken on iOS 16
PYTHON3=$(jbroot /usr/bin/python3)
for PYVER in \
    "$(jbroot /usr/bin/python3.11)" \
    "$(jbroot /usr/bin/python3.10)" \
    "$(jbroot /usr/bin/python3.9)" \
    "$(jbroot /usr/bin/python3.8)" \
    "$(jbroot /bin/python3.7)" \
    "$(jbroot /bin/python3)" \
    /usr/bin/python3 \
    /bin/python3; do
    if [ -x "$PYVER" ]; then
        ln -sf "$PYVER" "$PYTHON3"
        break
    fi
done

# Install zxtouch Python module into all known package locations (site-packages and dist-packages)
SRC=$(jbroot /usr/lib/python3.7/site-packages)/zxtouch
LIBBASE=$(jbroot /usr/lib)
for SP in "$LIBBASE"/python3*/site-packages "$LIBBASE"/python3*/dist-packages "$LIBBASE"/python3/dist-packages; do
    if [ -d "$SP" ] && [ "$SP" != "$(jbroot /usr/lib/python3.7/site-packages)" ]; then
        rm -rf "$SP/zxtouch"
        cp -R "$SRC" "$SP/" 2>/dev/null || true
    fi
done

# Re-sign app with roothide entitlements
APP=$(jbroot /Applications/zxtouch.app)
rm -f "$APP/embedded.mobileprovision"
cat > /tmp/zxtouch-ent.plist << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>platform-application</key><true/>
    <key>com.apple.private.skip-library-validation</key><true/>
    <key>com.apple.private.security.no-container</key><true/>
    <key>com.apple.private.security.no-sandbox</key><true/>
    <key>com.apple.private.security.storage.AppBundles</key><true/>
    <key>com.apple.private.security.storage.AppDataContainers</key><true/>
    <key>get-task-allow</key><true/>
    <key>application-identifier</key><string>com.zjx.zxtouch</string>
</dict>
</plist>
EOF
LDID=$(jbroot /usr/bin/ldid)
if [ -x "$LDID" ]; then
    "$LDID" -S/tmp/zxtouch-ent.plist "$APP/zxtouch"
fi

# Never restart SpringBoard from a maintainer script. Package managers run this
# inside the dpkg transaction, so a restart can kill their helper before dpkg
# records the package as configured. Sileo can offer a respring after dpkg exits.
exit 0
