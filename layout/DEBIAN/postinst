#!/bin/sh

# Register app with SpringBoard (rootless uicache)
if [ -x /var/jb/usr/bin/uicache ]; then
    /var/jb/usr/bin/uicache -a
else
    su mobile -c uicache 2>/dev/null || true
fi

# sudoers.d is writable on rootless; /etc/sudoers is not
SUDOERS_D="/var/jb/etc/sudoers.d"
if [ -d "$SUDOERS_D" ]; then
    echo "mobile ALL=(root) NOPASSWD:/var/jb/usr/bin/zxtouchb" > "$SUDOERS_D/zxtouch"
    chmod 440 "$SUDOERS_D/zxtouch"
fi

# Create required app directories
mkdir -p /var/mobile/Library/ZXTouch/scripts/recording/
mkdir -p /var/mobile/Library/ZXTouch/config/tweak/
mkdir -p /var/mobile/Library/ZXTouch/coreutils/ScriptRuntime/

# Copy example scripts (only if not already there)
EXAMPLES=/var/jb/usr/share/zxtouch/examples
if [ -d "$EXAMPLES" ]; then
    cp -rn "$EXAMPLES/"* /var/mobile/Library/ZXTouch/scripts/ 2>/dev/null || true
fi

chown -R mobile:mobile /var/mobile/Library/ZXTouch

# Point python3 to the highest working version (3.7 is broken on iOS 16)
for VER in python3.11 python3.10 python3.9 python3.8; do
    PYBIN=/var/jb/usr/bin/$VER
    if [ -x "$PYBIN" ]; then
        ln -sf "$PYBIN" /var/jb/usr/bin/python3
        ln -sf "$PYBIN" /var/jb/bin/python3
        break
    fi
done

# Install zxtouch Python module into all known package locations
SRC=/var/jb/usr/lib/python3.7/site-packages/zxtouch
for SP in /var/jb/usr/lib/python3*/site-packages /var/jb/usr/lib/python3*/dist-packages /var/jb/usr/lib/python3/dist-packages; do
    if [ -d "$SP" ] && [ "$SP" != "/var/jb/usr/lib/python3.7/site-packages" ]; then
        cp -rn "$SRC" "$SP/" 2>/dev/null || true
    fi
done

# Strip expired dev provisioning profile and re-sign with ldid
APP=/var/jb/Applications/zxtouch.app
rm -f "$APP/embedded.mobileprovision"
cat > /tmp/zxtouch-ent.plist << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>platform-application</key><true/>
    <key>com.apple.private.skip-library-validation</key><true/>
    <key>com.apple.private.security.no-container</key><true/>
    <key>com.apple.private.security.no-sandbox</key><true/>
    <key>com.apple.private.security.storage.AppBundles</key><true/>
    <key>com.apple.private.security.storage.AppDataContainers</key><true/>
    <key>get-task-allow</key><true/>
    <key>application-identifier</key><string>com.zjx.zxtouch</string>
</dict>
</plist>
EOF
if [ -x /var/jb/usr/bin/ldid ]; then
    /var/jb/usr/bin/ldid -S/tmp/zxtouch-ent.plist "$APP/zxtouch"
fi
